# ── Discord ──────────────────────────────────────────────────────────────────
# Token del bot: discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=

# ID y clave pública de la aplicación (opcionales para el bot en sí)
APP_ID=
PUBLIC_KEY=

# ── Comandos ─────────────────────────────────────────────────────────────────
# Prefijo de todos los comandos. Default: g!
PREFIX=g!

# ── Navidrome (opcional) ─────────────────────────────────────────────────────
# Necesario solo si quieres usar g!play nav:<búsqueda>
# Crea un usuario de solo lectura en el panel de administración de Navidrome
NAVIDROME_URL=http://192.168.0.130:4533
NAVIDROME_USER=
NAVIDROME_PASS=

# ── yt-dlp ───────────────────────────────────────────────────────────────────
# Solo necesario en Windows si yt-dlp no está en el PATH.
# En Linux/Docker deja esta línea comentada o vacía.
#
# Para encontrar la ruta en Windows tras instalar con pip:
#   pip show -f yt-dlp
# Ejemplo:
# YTDLP_PATH=C:\Users\TuUsuario\AppData\Local\...\Scripts\yt-dlp.exe
YTDLP_PATH=
